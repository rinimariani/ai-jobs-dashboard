# Copy this file to .env and fill in real values. Never commit .env.

# Write-role connection, used only by etl/load_to_db.py to load/refresh data.
ETL_DATABASE_URL=postgresql+psycopg2://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Read-only role connection, used by the Streamlit dashboard (dashboard/db.py).
DATABASE_URL=postgresql+psycopg2://readonly_user:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres
